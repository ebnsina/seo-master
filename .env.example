# Database (required)
DATABASE_URL="postgres://user:password@host:port/db-name"

# Background jobs (optional). With Redis set, crawls + rank refreshes run via a
# BullMQ worker (plus a daily rank sweep). Without it, crawls run in-process and
# rank refresh stays manual.
REDIS_URL=""          # e.g. redis://localhost:6379

# PageSpeed Insights (optional). Audits work without it, but the keyless API is
# heavily rate-limited — add a key for reliable Core Web Vitals.
# Get one in Google Cloud Console (enable "PageSpeed Insights API").
PAGESPEED_API_KEY=""

# Google Search Console integration (optional).
# When unset, "Submit to Google" falls back to guided manual instructions.
# Create an OAuth 2.0 Client (type: Web application) in Google Cloud Console,
# enable the Search Console API, and add <your-origin>/auth/google/callback as
# an authorized redirect URI.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Optional override; defaults to <request-origin>/auth/google/callback
GOOGLE_REDIRECT_URI=""
# Base64-encoded 32-byte key for encrypting stored OAuth tokens at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=""

# Keyword metrics provider (optional). Without these, keyword research still
# returns ideas + intent + clustering — just no search volume / difficulty.
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""

# AI content drafting (optional, provider-agnostic via TanStack AI).
# Pick any provider — openai | anthropic | gemini | ollama. Without these,
# content briefs still work; you just don't get the AI title/meta/outline.
AI_PROVIDER=""        # e.g. openai
AI_MODEL=""           # e.g. gpt-4o  /  claude-sonnet-4-6  /  gemini-2.5-pro  /  llama3
AI_API_KEY=""         # provider API key (omit for ollama)
